# Copy to `.dev.vars` (gitignored) for `wrangler dev`.

# Unguessable path segment that gates the endpoint.
SECRET_PATH=generate-a-long-random-string

# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenGoesHere

# Chat/user id messages default to.
TELEGRAM_DEFAULT_CHAT_ID=123456789
